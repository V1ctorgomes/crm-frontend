# Copie para `.env.local` e preencha. Nunca commite o `.env` real.

NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001
BACKEND_INTERNAL_URL=http://localhost:3001

# Mesmo valor público do VAPID no backend
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Origem pública do bucket R2 (para detetar URLs que devem passar pelo proxy autenticado)
NEXT_PUBLIC_R2_PUBLIC_URL=

# Mesmo segredo do backend (validação de papel no middleware)
JWT_SECRET=
